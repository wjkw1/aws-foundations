# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored - never commit it.

aws_region = "ap-southeast-2"

user_email      = "you@example.com"
user_first_name = "Your"
user_last_name  = "Name"

# Security baseline
monthly_budget_usd            = 50  # alert at 80% actual + 100% forecasted
cloudtrail_log_retention_days = 30

# GitHub OIDC policy

github_org = "Your GitHub organisation or username that owns the repository"
tf_state_bucket = "tfstate-<account-id>-example-aws-foundations"
